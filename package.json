{
  "name": "surreal-migrator",
  "version": "0.1.1",
  "description": "Interactive SurrealDB migration CLI",
  "type": "module",
  "bin": {
    "surreal-migrator": "./src/index.ts"
  },
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "start": "bun run src/index.ts",
    "typecheck": "tsc --noEmit",
    "build": "mkdir -p dist && bun build --compile --define __SM_TS_MIGRATIONS__=false ./src/index.ts --outfile dist/surreal-migrator",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release:npm": "changeset publish"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "keywords": [
    "surrealdb",
    "migrations",
    "cli",
    "bun"
  ],
  "license": "MIT",
  "devDependencies": {
    "@changesets/cli": "^2.31.1",
    "@surrealdb/node": "^3.0.3",
    "@types/bun": "^1.3.14"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@opentui/core": "^0.4.5",
    "surrealdb": "^2.0.4"
  }
}
